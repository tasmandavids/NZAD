{
  "name": "olune",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "22.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "typecheck": "tsc --noEmit --incremental false",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "INTEGRATION_TEST=1 node --env-file=.env.local ./node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "db:status": "supabase migration list",
    "db:push": "supabase db push --linked --yes",
    "db:push:remote": "supabase db push --linked --yes",
    "db:push:local": "supabase db reset --yes",
    "db:sync": "bash scripts/db-sync.sh",
    "db:sync:remote": "bash scripts/db-sync.sh --remote",
    "db:sync:local": "bash scripts/db-sync.sh --local",
    "db:verify": "node --env-file=.env.local scripts/verify-migrations.mjs",
    "setup:all": "bash scripts/setup-all.sh",
    "db:pull": "supabase db pull",
    "db:reset": "supabase db reset",
    "seed:platform-admin": "node --env-file=.env.local scripts/seed-platform-admin.mjs",
    "staging:verify": "node --env-file=.env.local scripts/staging-verify.mjs",
    "setup:oauth": "node --env-file=.env.local scripts/setup-oauth.mjs"
  },
  "dependencies": {
    "@hello-pangea/dnd": "^18.0.1",
    "@react-three/fiber": "^9.1.0",
    "@stripe/react-stripe-js": "^6.6.0",
    "@stripe/stripe-js": "^9.8.0",
    "@supabase/ssr": "^0.12.0",
    "@supabase/supabase-js": "^2.108.2",
    "@types/qrcode": "^1.5.6",
    "@vercel/analytics": "^2.0.1",
    "@vercel/speed-insights": "^2.0.0",
    "framer-motion": "^11.11.0",
    "imapflow": "^1.4.2",
    "immer": "^11.1.8",
    "next": "^15.1.0",
    "next-intl": "^4.13.0",
    "nodemailer": "^9.0.1",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "recharts": "^3.8.1",
    "stripe": "^22.2.2",
    "three": "^0.169.0",
    "xero-node": "^18.0.0",
    "zod": "^3.23.8",
    "zustand": "^5.0.14"
  },
  "overrides": {
    "postcss": "^8.5.10"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.1",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.169.0",
    "eslint": "^9.0.0",
    "eslint-config-next": "^15.1.0",
    "supabase": "^2.107.0",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.9",
    "ws": "^8.21.0"
  }
}
