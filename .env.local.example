# Copy to .env.local and fill in (Supabase → Settings → API).
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY
# Service-role key — used only by webhook + cron handlers (bypasses RLS). Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Optional — only for Supabase CLI (npx supabase login / db push). Not needed when GitHub integration deploys migrations.
# SUPABASE_ACCESS_TOKEN=your-personal-access-token
# Database password for `supabase link` / `db push` (Project Settings → Database).
# SUPABASE_DB_PASSWORD=your-database-password
# SUPABASE_PROJECT_REF=wnoxcwihrzbxvogvmhqv

# Shared secret for the notifications cron. Vercel Cron sends it as a Bearer token.
CRON_SECRET=generate-a-long-random-string

# OAuth — see docs/OAUTH_SETUP.md. Run: node --env-file=.env.local scripts/setup-oauth.mjs
# GOOGLE_OAUTH_CLIENT_ID=
# GOOGLE_OAUTH_CLIENT_SECRET=
# APPLE_OAUTH_CLIENT_ID=
# APPLE_OAUTH_CLIENT_SECRET=

# Connected inbox OAuth (separate from login — needs Gmail / Graph mail scopes).
# Gmail: use a dedicated OAuth client or reuse GOOGLE_OAUTH_* with Gmail API enabled.
# GOOGLE_MAIL_CLIENT_ID=
# GOOGLE_MAIL_CLIENT_SECRET=
# Microsoft: Azure App Registration → Mail.Read, Mail.Send, offline_access.
# MICROSOFT_MAIL_CLIENT_ID=
# MICROSOFT_MAIL_CLIENT_SECRET=
# MICROSOFT_MAIL_TENANT=common

# Encrypts stored mailbox credentials (32-byte secret; CRON_SECRET is used as fallback).
# EMAIL_TOKEN_ENCRYPTION_KEY=generate-a-long-random-string
# EMAIL_OAUTH_STATE_SECRET=generate-a-long-random-string

# Optional — AI conversation summaries (falls back to heuristic summary without this).
# OPENAI_API_KEY=
# OPENAI_SUMMARY_MODEL=gpt-4o-mini

# Your apex domain. Use "localhost" in dev so <slug>.localhost:3000 resolves a tenant.
NEXT_PUBLIC_ROOT_DOMAIN=localhost

# Custom domain DNS targets (shown in the domain setup wizard).
NEXT_PUBLIC_DOMAIN_CNAME_TARGET=cname.vercel-dns.com
NEXT_PUBLIC_DOMAIN_APEX_IP=216.198.79.1

# Stripe (Dashboard → Developers → API keys).
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Publishable key is exposed to the browser for Stripe.js / PaymentElement.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# Comma-separated emails with access to /platform (Olune operator console).
# Also insert into platform_operators for persistent access without env changes.
# Test seed account: platform-admin@olune.test (see TEST_ACCOUNTS.md)
PLATFORM_OPERATOR_EMAILS=platform-admin@olune.test


# Outbound notification delivery (OPTIONAL — delivery no-ops if unset).
# Email via Resend (https://resend.com → API Keys). RESEND_FROM must be a
# verified sender, e.g. "Olune <noreply@yourdomain.com>".
RESEND_API_KEY=re_...
RESEND_FROM=Olune <noreply@yourdomain.com>
# SMS via Twilio (Console → Account Info + a Messaging number in E.164).
TWILIO_ACCOUNT_SID=AC...
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_FROM=+6421234567
